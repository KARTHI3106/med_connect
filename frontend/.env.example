# Frontend Environment Variables
# Copy this file to .env and fill in the values

# Backend API URL
# For local development with Vite proxy: /api
# For production (Vercel): https://your-backend.onrender.com/api
VITE_API_URL=/api

# Backend Socket.IO URL
# Optional in local (defaults to http://localhost:3001)
# Recommended in production: https://your-backend.onrender.com
VITE_SOCKET_URL=

# Deployed smart contract address on Polygon Amoy
VITE_CONTRACT_ADDRESS=0x_your_contract_address_here
